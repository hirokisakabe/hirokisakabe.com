---
import Layout from "../../layouts/Layout.astro";
import { getPostIds, getPostDetail, extractDescription } from "../../lib/post";
import { format } from "date-fns";

export async function getStaticPaths() {
  const ids = await getPostIds();

  return ids.map((id) => ({
    params: {
      postId: id,
    },
  }));
}

const { postId } = Astro.params;

const postDetail = await getPostDetail(postId);
---

<Layout
  title={postDetail.title}
  path={`/posts/${postId}/`}
  thumbnail={`/posts/${postId}/ogp.png`}
  description={extractDescription(postDetail.body)}
>
  <div class="rounded-lg px-3 py-5 shadow-md">
    <h1 class="text-2xl font-medium">{postDetail.title}</h1>
    <div class="pt-3 text-xs text-slate-600">
      {format(postDetail.publishedAt, "yyyy/MM/dd")}
    </div>
    <div
      class="prose prose-sm prose-h1:text-xl prose-h2:text-lg prose-h3:text-base prose-img:max-w-full prose-img:rounded-xl lg:prose-img:max-w-xl mt-5 max-w-none"
    >
      <postDetail.Content />
    </div>
  </div>
</Layout>
